{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glin's Studio",
  "version": "0.1.0",
  "identifier": "com.glins.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Glin's Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3MDU2QTgwOTIwRTg5MTMKUldRVGlRNlNnR29GeHdQcGRFUTF0bW1kTTlrWmtzc1luSGtCV3ZGa3B1QVZHMGwwcjNhK0cxWU0K",
      "endpoints": [
        "https://github.com/Pedro-P-Gomes-alt/Glin-s-Studio-App/releases/latest/download/latest.json"
      ]
    }
  }
}
